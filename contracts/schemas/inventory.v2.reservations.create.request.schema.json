{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InventoryV2ReservationsCreateRequest",
  "type": "object",
  "required": ["productId", "warehouseId", "locationId", "quantityReserved"],
  "properties": {
    "productId":        { "type": ["string", "number"] },
    "variantId":        { "type": ["string", "number", "null"] },
    "lotId":            { "type": ["string", "number", "null"] },
    "warehouseId":      { "type": ["string", "number"] },
    "locationId":       { "type": ["string", "number"] },
    "quantityReserved": { "type": "number", "exclusiveMinimum": 0 },
    "referenceType":    { "type": "string" },
    "referenceId":      { "type": "string" },
    "referenceCode":    { "type": "string" },
    "notes":            { "type": "string" }
  }
}
