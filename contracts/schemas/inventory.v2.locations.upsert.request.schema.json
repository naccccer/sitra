{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InventoryV2LocationsUpsertRequest",
  "type": "object",
  "required": ["warehouseId", "locationKey", "name", "usageType"],
  "properties": {
    "id": { "type": ["string", "number"] },
    "warehouseId": { "type": ["string", "number"] },
    "parentLocationId": { "type": ["string", "number", "null"] },
    "locationKey": { "type": "string" },
    "name": { "type": "string" },
    "usageType": { "type": "string", "enum": ["internal", "supplier", "customer", "inventory", "production"] },
    "notes": { "type": "string" },
    "isActive": { "type": "boolean" }
  }
}
