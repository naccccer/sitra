{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CatalogSaveRequest",
  "type": "object",
  "required": ["glasses", "operations", "connectors", "fees"],
  "properties": {
    "glasses": { "type": "array", "items": { "type": "object" } },
    "thicknesses": { "type": "array", "items": { "type": "integer" } },
    "operations": { "type": "array", "items": { "type": "object" } },
    "connectors": { "type": "object" },
    "fees": { "type": "object" },
    "factoryLimits": {
      "type": "object",
      "properties": {
        "maxShortSideCm": { "type": "integer", "minimum": 0 },
        "maxLongSideCm": { "type": "integer", "minimum": 0 },
        "minimumChargeEnabled": { "type": "boolean" },
        "minimumChargeThresholdM2": { "type": "number", "minimum": 0 },
        "minimumBillableAreaM2": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "jumboRulesEnabled": { "type": "boolean" },
    "jumboRules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "shortSideOverCm": { "type": "integer", "minimum": 0 },
          "longSideOverCm": { "type": "integer", "minimum": 0 },
          "adjustmentType": { "type": "string", "enum": ["percentage", "fixed"] },
          "adjustmentValue": { "type": "integer", "minimum": 0 },
          "sortOrder": { "type": "integer", "minimum": 0 }
        },
        "required": ["id"],
        "additionalProperties": false
      }
    },
    "roundStep": { "type": "number" }
  },
  "additionalProperties": true
}
