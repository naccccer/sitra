{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccountingPayrollImportRequest",
  "type": "object",
  "required": ["rows"],
  "properties": {
    "periodId": { "type": ["string", "number"] },
    "periodKey": { "type": "string" },
    "year": { "type": "integer" },
    "month": { "type": "integer", "minimum": 1, "maximum": 12 },
    "title": { "type": "string" },
    "startDate": { "type": "string" },
    "endDate": { "type": "string" },
    "payDate": { "type": "string" },
    "notes": { "type": "string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "anyOf": [
          { "required": ["employeeId"] },
          { "required": ["employeeCode"] }
        ],
        "properties": {
          "employeeId": { "type": ["string", "number"] },
          "employeeCode": { "type": "string" },
          "inputs": {
            "type": ["array", "object"]
          },
          "notes": { "type": "string" },
          "clientRequestId": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}
