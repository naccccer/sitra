# Frontend dev proxy target (without /api at the end).
VITE_DEV_API_TARGET=http://127.0.0.1
VITE_API_TIMEOUT_MS=10000
# App base path for BrowserRouter/Vite build. Use / for root or /sitra/ for subpath.
VITE_APP_BASE=/

# Backend database (read by PHP from .env/.env.local or env/env.local).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sitra
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_CONNECT_TIMEOUT=5

# Optional API/runtime flags.
APP_DEBUG=1
APP_OWNER_UID=1

# CORS allowed origins (comma-separated).
# In LOCAL DEV, leave this unset — the PHP backend falls back to 127.0.0.1:5173 / localhost:5173.
# In PRODUCTION, set this to your actual domain(s) to prevent open CORS.
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# APP_ENV=production
