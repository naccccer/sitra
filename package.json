{
  "name": "sitra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:encoding && npm run check:ui-fa && vite build",
    "lint": "npm run check:encoding && npm run check:ui-fa && npm run check:boundaries && eslint .",
    "check:encoding": "node scripts/check-encoding.js",
    "check:encoding:changed": "node scripts/check-encoding.js --changed",
    "check:ui-fa": "node scripts/check-ui-fa.js",
    "check:boundaries": "node scripts/check-boundaries.js",
    "check:boundaries:changed": "node scripts/check-boundaries.js --changed",
    "lint:changed": "node scripts/lint-changed.js",
    "verify:fast": "npm run check:encoding:changed && npm run check:ui-fa && npm run check:boundaries:changed && npm run lint:changed",
    "verify:safe": "npm run lint && npm run build",
    "env:home": "node scripts/switch-env.js home",
    "env:office": "node scripts/switch-env.js office",
    "env:status": "node scripts/switch-env.js status",
    "auth:reset-admin": "php scripts/reset-admin-password.php",
    "smoke:production": "php scripts/smoke-production-flow.php",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-date-object": "^2.1.9",
    "react-dom": "^19.2.0",
    "react-multi-date-picker": "^4.5.2",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
