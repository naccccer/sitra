{
  "name": "sitra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "deps:install": "npm ci --prefer-offline --no-audit --no-fund",
    "dev": "vite",
    "build": "npm run contracts:types && npm run check:encoding && npm run check:ui-fa && npm run check:file-size && npm run check:naming && vite build",
    "lint": "npm run check:encoding && npm run check:ui-fa && npm run check:boundaries && npm run check:file-size && npm run check:naming && eslint .",
    "check:encoding": "node scripts/check-encoding.js",
    "check:encoding:changed": "node scripts/check-encoding.js --changed",
    "check:ui-fa": "node scripts/check-ui-fa.js",
    "check:boundaries": "node scripts/check-boundaries.js",
    "check:boundaries:changed": "node scripts/check-boundaries.js --changed",
    "check:file-size": "node scripts/check-file-size.js",
    "check:file-size:changed": "node scripts/check-file-size.js --changed",
    "check:naming": "node scripts/check-naming.js",
    "check:naming:changed": "node scripts/check-naming.js --changed",
    "check:doc-contract-sync": "node scripts/check-doc-contract-sync.js --changed",
    "lint:changed": "node scripts/lint-changed.js",
    "verify:fast": "npm run check:encoding:changed && npm run check:ui-fa && npm run check:boundaries:changed && npm run check:file-size:changed && npm run check:naming:changed && npm run lint:changed",
    "verify:safe": "npm run check:doc-contract-sync && npm run lint && npm run test:all && npm run build",
    "env:home": "node scripts/switch-env.js home",
    "env:office": "node scripts/switch-env.js office",
    "env:status": "node scripts/switch-env.js status",
    "auth:reset-admin": "php scripts/reset-admin-password.php",
    "db:reset-minimal": "php scripts/reset-minimal-fixture.php",
    "contracts:types": "node scripts/generate-contract-types.js",
    "preview": "vite preview",
    "test:preflight": "node scripts/check-test-env.js",
    "test": "npm run test:preflight && node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "npm run test:preflight && node ./node_modules/vitest/vitest.mjs",
    "test:coverage": "npm run test:preflight && node ./node_modules/vitest/vitest.mjs run --coverage && node scripts/check-critical-coverage.js",
    "test:php": "php tests/php/run.php",
    "test:all": "npm test && npm run test:php"
  },
  "dependencies": {
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-date-object": "^2.1.9",
    "react-dom": "^19.2.0",
    "react-multi-date-picker": "^4.5.2",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
